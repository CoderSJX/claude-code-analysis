---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ArchitectureExplorer from '../components/ArchitectureExplorer';
import { parts, chapters } from '../book.config';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<BaseLayout
  title="Claude Code from Source - 架构、模式与内部实现"
  description="一本解析 Anthropic AI 编码智能体架构的技术书。18 章、400 页，基于 source map 逆向整理。不含源代码，只保留可迁移的模式。"
>
  <Header />

  <main class="max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20">

    <!-- Hero -->
    <div class="text-center mb-20">
      <img
        src={`${base}cover.jpg`}
        alt="Claude Code from Source - 书封"
        class="mx-auto w-64 md:w-72 rounded-lg shadow-lg mb-10"
      />
      <h1 class="text-3xl md:text-4xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-6 leading-tight">
        Anthropic 是如何打造出最广泛使用的<br class="hidden md:inline" /> AI 编码智能体的
      </h1>
      <p class="text-lg text-[var(--color-secondary)] dark:text-[var(--color-muted)] max-w-2xl mx-auto leading-relaxed mb-6">
        Claude Code 发布到 npm 时，也一并带上了 source map。我们逐个阅读了所有文件。这本书把架构、设计决策和可迁移模式提炼成
        <span class="text-[var(--color-terracotta)] font-medium">18 章</span>，供你学习并应用到自己的系统中。
      </p>
      <a
        href={`${base}${chapters[0].slug}/`}
        class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-terracotta)] text-white font-medium rounded-lg hover:opacity-90 transition-opacity"
      >
        开始阅读
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- What You'll Learn -->
    <section class="mb-20">
      <h2 class="text-2xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-8">
        你将学到什么
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: '智能体循环', text: '一个 async generator 驱动整个系统 - 流式输出模型结果、执行工具、从错误中恢复，并通过 4 层压缩上下文。' },
          { title: '大规模工具执行', text: '从模型请求到工具结果的 14 步流水线。包括权限判定、投机执行，以及按安全级别并发批处理。' },
          { title: '多智能体编排', text: '子智能体如何共享提示缓存前缀，把成本降低 95%。包括 Fork 智能体、协调者模式、带邮箱消息的蜂群团队。' },
          { title: '没有数据库的记忆', text: '基于文件的记忆系统，结合 LLM 召回。4 类记忆、陈旧性提示，以及比 embedding 搜索更强的 Sonnet 侧查询。' },
          { title: '性能工程', text: '通过并行 I/O 实现 240ms 启动。Slot 预留让 99% 的请求都能节省上下文。用于模糊搜索的位图预过滤。每一毫秒都被计算。' },
          { title: '可扩展性与安全', text: '两阶段技能加载（启动时读元数据，按需读内容）。27 个生命周期 Hooks，在启动时冻结配置快照，防止注入。' },
        ].map(({ title, text }) => (
          <div class="p-5 rounded-lg border border-[var(--color-border)] dark:border-[#333]">
            <h3 class="font-semibold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-2">{title}</h3>
            <p class="text-sm text-[var(--color-secondary)] dark:text-[var(--color-muted)] leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Architecture Explorer -->
    <section class="mb-20">
      <h2 class="text-2xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-3">
        探索架构
      </h2>
      <p class="text-sm text-[var(--color-muted)] mb-6">
        6 个核心抽象驱动着 Claude Code。你可以拖动节点重新排列，悬停查看详情，点击跳转到对应章节。
      </p>
      <ArchitectureExplorer client:only="react" className="w-full" />
    </section>

    <!-- Who This Is For -->
    <section class="mb-20">
      <h2 class="text-2xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-6">
        适合谁看
      </h2>
      <div class="space-y-4 text-[var(--color-secondary)] dark:text-[var(--color-muted)]">
        <p><strong class="text-[var(--color-charcoal)] dark:text-[var(--color-cream)]">正在构建 agent 系统的工程师。</strong> 每章末尾都有“应用到实践” - 5 个可迁移模式和具体改造建议。直接借鉴架构，跳过踩坑。</p>
        <p><strong class="text-[var(--color-charcoal)] dark:text-[var(--color-cream)]">评估架构的技术负责人。</strong> 即使不看每个代码块，也能跟着叙述理解这些决策为什么这么做，而不只是做了什么。</p>
        <p><strong class="text-[var(--color-charcoal)] dark:text-[var(--color-cream)]">对生产级 AI 工具如何工作的任何好奇者。</strong> Claude Code 被几十万开发者使用。这就是它在底层如何运作的。</p>
      </div>
    </section>

    <!-- Table of Contents -->
    <section class="mb-20">
      <h2 class="text-2xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-8">
        目录
      </h2>
      {parts.map((part) => {
        const partChapters = chapters.filter(c => part.chapters.includes(c.number));
        return (
          <div class="mb-10">
            <div class="flex items-baseline gap-3 mb-1">
              <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-terracotta)]">第 {part.number} 部分</span>
              <h3 class="text-lg font-bold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] font-[var(--font-serif)]">{part.title}</h3>
            </div>
            <p class="text-sm italic text-[var(--color-muted)] mb-4">{part.epigraph}</p>

            <div class="space-y-2">
              {partChapters.map((ch) => (
                <a
                  href={`${base}${ch.slug}/`}
                  class="group flex items-start gap-3 p-3 -mx-3 rounded-lg hover:bg-[var(--color-beige)] dark:hover:bg-[var(--color-dark-surface)] transition-colors"
                >
                  <span class="text-sm font-mono text-[var(--color-muted)] mt-0.5 w-6 shrink-0 text-right">{ch.number}</span>
                  <div>
                    <span class="text-[var(--color-charcoal)] dark:text-[var(--color-cream)] group-hover:text-[var(--color-terracotta)] font-medium transition-colors">
                      {ch.title}
                    </span>
                    <p class="text-sm text-[var(--color-muted)] mt-0.5">{ch.description}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </section>

    <!-- How This Was Made -->
    <section class="mb-20">
      <h2 class="text-2xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-6">
        本书如何制作
      </h2>
      <div class="space-y-4 text-[var(--color-secondary)] dark:text-[var(--color-muted)] leading-relaxed">
        <p>
          源码是从 npm source map 中提取出来的 - Claude Code 随包发布的 <code>.js.map</code> 文件里包含了 <code>sourcesContent</code> 字段，保存着完整的原始 TypeScript。几乎两千个文件构成了完整架构。
        </p>
        <p>
          <strong class="text-[var(--color-charcoal)] dark:text-[var(--color-cream)]">36 个 AI 智能体</strong> 分四个阶段完成了整本书的分析与撰写：
        </p>
        <div class="grid sm:grid-cols-2 gap-4 my-6">
          {[
            { phase: '探索', detail: '6 个并行智能体阅读了源码树中的每个文件' },
            { phase: '分析', detail: '12 个智能体写出了 494KB 的原始技术文档' },
            { phase: '写作', detail: '15 个智能体将一切从零重写为叙事章节' },
            { phase: '审阅与修订', detail: '3 位审阅者给出 900 行反馈；3 个智能体完成全部修复' },
          ].map(({ phase, detail }) => (
            <div class="flex gap-3 items-start p-4 rounded-lg bg-[var(--color-beige)]/50 dark:bg-[var(--color-dark-surface)]/50">
              <span class="text-[var(--color-terracotta)] font-semibold text-sm shrink-0">{phase}</span>
              <span class="text-sm">{detail}</span>
            </div>
          ))}
        </div>
        <p>
          从源码提取到最终修订完成，整个过程大约用了 <strong class="text-[var(--color-charcoal)] dark:text-[var(--color-cream)]">6 小时</strong>。最后的审计确保没有逐字保留任何源码 - 每个代码块都被改写成了使用不同变量名的伪代码。
        </p>
      </div>
    </section>

    <!-- 10 Patterns -->
    <section class="mb-20">
      <h2 class="text-2xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-3">
        让它运转起来的 10 个模式
      </h2>
      <p class="text-[var(--color-muted)] mb-6">如果你只读这一段，也足够理解定义 Claude Code 的那些架构取舍了。</p>
      <div class="space-y-4">
        {[
          { name: '将 AsyncGenerator 用作智能体循环', desc: '返回 Messages，Terminal 有类型返回值，自然支持背压和取消' },
          { name: '投机式工具执行', desc: '在模型流式输出期间就启动只读工具，等响应完成前先跑起来' },
          { name: '并发安全批处理', desc: '按安全性分组工具，只读并行、写入串行' },
          { name: '用 Fork 智能体共享缓存', desc: '并行子任务共享字节完全一致的提示前缀，节省约 95% 输入 Token' },
          { name: '4 层上下文压缩', desc: 'snip、microcompact、collapse、autocompact - 一层比一层轻' },
          { name: '结合 LLM 召回的文件型记忆', desc: 'Sonnet 侧查询选择相关记忆，而不是关键词匹配' },
          { name: '两阶段技能加载', desc: '启动时只读 frontmatter，调用时再加载完整内容' },
          { name: '用于缓存稳定性的粘性锁存器', desc: '一旦发出 beta header，整个会话中都不会撤销' },
          { name: 'Slot 预留', desc: '默认 8K 输出上限，命中后提升到 64K（99% 的请求都能省上下文）' },
          { name: 'Hook 配置快照', desc: '在启动时冻结，防止运行时注入攻击' },
        ].map((p, i) => (
          <div class="flex gap-4 items-start">
            <span class="text-sm font-mono text-[var(--color-terracotta)] font-bold mt-1 w-6 shrink-0 text-right">{i + 1}</span>
            <div>
              <span class="font-semibold text-[var(--color-charcoal)] dark:text-[var(--color-cream)]">{p.name}</span>
              <span class="text-[var(--color-secondary)] dark:text-[var(--color-muted)]"> — {p.desc}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Disclaimer -->
    <section class="mb-12 p-6 rounded-lg border border-[var(--color-border)] dark:border-[#333] bg-[var(--color-beige)]/50 dark:bg-[var(--color-dark-surface)]/50">
      <p class="text-sm text-[var(--color-secondary)] dark:text-[var(--color-muted)] leading-relaxed">
        <strong class="text-[var(--color-charcoal)] dark:text-[var(--color-cream)]">纯属教学用途。</strong> 本书不包含 Claude Code 的任何源码 - 每个代码块都是原创伪代码，用来说明架构模式。目标是帮助工程师理解生产级 AI 智能体如何构建，而不是复现专有软件。“NO'REILLY”封面只是用于说明的戏仿/梗图，与 O'Reilly Media 没有任何关联。
      </p>
    </section>

    <!-- Footer -->
    <footer class="text-center text-sm text-[var(--color-muted)] border-t border-[var(--color-border)] dark:border-[#333] pt-8 pb-12">
      <p>
        独立的教育性分析，与
        <a href="https://anthropic.com" class="text-[var(--color-terracotta)] hover:underline">Anthropic</a> 无关，也未获其认可或赞助。
      </p>
      <p class="mt-2">
        <a href="https://github.com/alejandrobalderas/claude-code-from-source" class="text-[var(--color-terracotta)] hover:underline">GitHub</a>
      </p>
    </footer>
  </main>
</BaseLayout>
